# NomadSpot Taiwan — BFF Environment Variables
# cp .env.example .env  and fill in real keys

PORT=3000

# CWA — Taiwan Central Weather Administration
# Endpoint: https://opendata.cwa.gov.tw/api/v1/rest/datastore/F-C0032-001
CWA_API_KEY=CWA-AF33C8B9-B433-4E68-961B-03769271D2F0

# MOE — Taiwan Ministry of Environment (AQI)
# Endpoint: https://data.moenv.gov.tw/api/v2/aqx_p_432
MOE_API_KEY=ddac4206-45a3-44f0-acea-566422a09c10

# TDX — Transport Data eXchange (scenic spots + YouBike)
# Register: https://tdx.transportdata.tw/register
TDX_CLIENT_ID=vrk.kao-c1fb6587-a6d5-46e8
TDX_CLIENT_SECRET=13c9fad7-b02b-486f-9c89-a471b8b699e6

OWM_API_KEY=afe86f9bb371ae9b3d278f5c3bdb132d

# CORS origin (use * for dev, set real domain for production)
ALLOWED_ORIGIN=*
